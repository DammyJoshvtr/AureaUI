{
  "expo": {
    "name": "Aurea Kit",
    "slug": "Aurea Kit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/logo.png",
    "scheme": "client",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#17181A",
        "foregroundImage": "./assets/logo/logo.png",
        "backgroundImage": "./assets/logo/logo.png",
        "monochromeImage": "./assets/logo/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.AureaKit"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo/logo.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      [
        "expo-calendar",
        {
          "calendarPermission": "The app needs to access your calendar."
        }
      ],

      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(AUREAUIKIT) to access your camera",
          "microphonePermission": "Allow $(AUREAUIKIT) to access your microphone",
          "recordAudioAndroid": true,
          "barcodeScannerEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
